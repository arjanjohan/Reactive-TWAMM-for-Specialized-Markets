# Environment Variables for TWAMM Hook Deployment

# Private key for deployment (keep this secret!)
PRIVATE_KEY=0x...

# RPC URLs
UNICHAIN_RPC=https://sepolia.unichain.org
ETHEREUM_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Contract Addresses (after deployment)
TWAMM_HOOK_ADDRESS=
REACTIVE_TWAMM_ADDRESS=

# Pool Manager (Unichain Sepolia)
POOL_MANAGER_ADDRESS=

# Etherscan API key for verification
ETHERSCAN_API_KEY=

# Reactive Network callback address
REACTIVE_CALLBACK_ADDRESS=
